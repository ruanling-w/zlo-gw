{
  "name": "zalo-api-gateway",
  "version": "0.1.0",
  "description": "Standalone API gateway for Zalo personal accounts via zca-js",
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "author": "monas-team",
  "repository": {
    "type": "git",
    "url": "https://github.com/monas-team/zaloclaw.git"
  },
  "bugs": {
    "url": "https://github.com/monas-team/zaloclaw/issues"
  },
  "homepage": "https://github.com/monas-team/zaloclaw#readme",
  "keywords": [
    "zalo",
    "chatbot",
    "zca-js",
    "messaging",
    "api-gateway",
    "http-api",
    "webhook"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:sharp --packages=external",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gateway": "tsx src/gateway/index.ts",
    "gateway:build": "esbuild src/gateway/index.ts --bundle --platform=node --format=esm --outfile=dist/gateway.js --external:sharp --packages=external",
    "bridge:hermes": "tsx src/bridge/hermes/index.ts",
    "bridge:hermes:build": "esbuild src/bridge/hermes/index.ts --bundle --platform=node --format=esm --outfile=dist/hermes-bridge.js --external:sharp --packages=external",
    "zalo:login": "tsx src/cli/zalo-login.ts",
    "zalo:status": "tsx src/cli/zalo-status.ts",
    "zalo:login:build": "esbuild src/cli/zalo-login.ts --bundle --platform=node --format=esm --outfile=dist/zalo-login.js --external:sharp --packages=external",
    "zalo:status:build": "esbuild src/cli/zalo-status.ts --bundle --platform=node --format=esm --outfile=dist/zalo-status.js --external:sharp --packages=external"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "jsqr": "^1.4.0",
    "pngjs": "^7.0.0",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.0",
    "zca-js": "^2.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.5",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist",
    "src",
    "docs",
    "index.ts",
    "tsconfig.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
