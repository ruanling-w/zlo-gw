{
  "name": "zaloclaw",
  "version": "2.0.3",
  "description": "OpenClaw channel plugin for Zalo personal accounts via zca-js",
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "author": "monasprox",
  "repository": {
    "type": "git",
    "url": "https://github.com/monasprox/zaloclaw.git"
  },
  "bugs": {
    "url": "https://github.com/monasprox/zaloclaw/issues"
  },
  "homepage": "https://github.com/monasprox/zaloclaw#readme",
  "keywords": [
    "openclaw",
    "zalo",
    "chatbot",
    "channel-plugin",
    "zca-js",
    "messaging"
  ],
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:openclaw --external:sharp --packages=external",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "jsqr": "^1.4.0",
    "pngjs": "^7.0.0",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.0",
    "zca-js": "^2.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
